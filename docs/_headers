# Cloudflare Pages / Netlify-style headers — security + caching.
# Ignored by GitHub Pages (which serves its own headers) but applied
# automatically the moment this folder is pointed at any modern static host.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), interest-cohort=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'
  X-Robots-Tag: index, follow, max-image-preview:large

# Long cache for evidence (immutable — fingerprinted in EVIDENCE_HASHES.txt)
/evidence/*
  Cache-Control: public, max-age=31536000, immutable

# Long cache for assets
/assets/*
  Cache-Control: public, max-age=2592000

# Short cache for HTML so updates propagate quickly
/*.html
  Cache-Control: public, max-age=300, must-revalidate

# 404 should not be cached aggressively
/404.html
  Cache-Control: public, max-age=60

/sitemap.xml
  Cache-Control: public, max-age=3600

/feed.xml
  Cache-Control: public, max-age=3600

/robots.txt
  Cache-Control: public, max-age=3600
